{
  "name": "@thermal-label/d1-core",
  "version": "0.6.1",
  "description": "Shared D1 tape-protocol encoder, status parser, and tape-type table for the LabelManager and LabelWriter Duo (tape side) drivers.",
  "keywords": [
    "thermal-label",
    "dymo",
    "d1",
    "labelmanager",
    "labelwriter-duo",
    "protocol"
  ],
  "type": "module",
  "author": "Mannes Brak",
  "license": "MIT",
  "homepage": "https://thermal-label.github.io/d1-core/",
  "repository": {
    "type": "git",
    "url": "https://github.com/thermal-label/d1-core.git"
  },
  "bugs": {
    "url": "https://github.com/thermal-label/d1-core/issues"
  },
  "funding": [
    {
      "type": "github",
      "url": "https://github.com/sponsors/mannes"
    },
    {
      "type": "ko-fi",
      "url": "https://ko-fi.com/mannes"
    }
  ],
  "files": [
    "dist",
    "data/media.json",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "compile-data": "node scripts/compile-data.mjs",
    "prebuild": "pnpm run compile-data",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "pnpm run compile-data && tsc -p tsconfig.json --noEmit",
    "test": "pnpm run compile-data && vitest run",
    "test:watch": "vitest",
    "test:coverage": "pnpm run compile-data && vitest run --coverage",
    "lint": "eslint src",
    "format": "prettier --write src",
    "docs:api": "pnpm run compile-data && typedoc"
  },
  "prettier": "@mbtech-nl/prettier-config",
  "engines": {
    "node": ">=20.9.0"
  },
  "dependencies": {
    "@mbtech-nl/bitmap": "^1.3.0",
    "@thermal-label/contracts": "^0.6.0"
  },
  "devDependencies": {
    "@mbtech-nl/eslint-config": "^1.1.0",
    "@mbtech-nl/prettier-config": "^1.1.0",
    "@mbtech-nl/tsconfig": "^1.1.0",
    "@vitest/coverage-v8": "^2.0.0",
    "eslint": "^9.0.0",
    "json5": "^2.2.3",
    "prettier": "^3.0.0",
    "typedoc": "^0.28.0",
    "typedoc-plugin-markdown": "^4.0.0",
    "typescript": "~5.5.0",
    "vitest": "^2.0.0"
  }
}
