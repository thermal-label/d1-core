    widthMm: 6,
    type: 'tape',
    category: 'cartridge',
    targetModels: ['d1'],
    defaultOrientation: 'horizontal',
    printMargins: { leftMm: 3, rightMm: 3, topMm: 0, bottomMm: 0 },
    skus: ['43613', 'S0720780'],
    material: 'standard',
    text: 'black',
    background: 'white',
    tapeWidthMm: 6,
    printableDots: 32,
    bytesPerLine: 4,
  },

